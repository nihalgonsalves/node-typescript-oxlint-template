{
  "name": "Node.js",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": ["oxc.oxc-vscode"]
    }
  },
  "mounts": [
    {
      "source": "/var/run/docker.sock",
      "target": "/var/run/docker.sock",
      "type": "bind"
    }
  ],
  "onCreateCommand": "pnpm install",
  "postCreateCommand": "sudo chown root:docker /var/run/docker.sock",
  "remoteUser": "node"
}
